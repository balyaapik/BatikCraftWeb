# Generate fresh production keys:
#   python -c "import secrets; print(secrets.token_urlsafe(60))"
DJANGO_SECRET_KEY=change-me-in-production
# Use a separate stable value so stored R2 credentials remain decryptable when
# DJANGO_SECRET_KEY is rotated.
BATIKCRAFT_CREDENTIAL_ENCRYPTION_KEY=change-me-with-another-long-random-value

DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=

# SQLite development default: leave DATABASE_URL empty.
# PostgreSQL: postgresql://USER:PASSWORD@HOST:5432/batikcraft
# MySQL:      mysql://USER:PASSWORD@127.0.0.1:3306/batikcraft
DATABASE_URL=

# Optional hardening. Both default to the safe value when DJANGO_DEBUG=False.
DJANGO_SECURE_SSL_REDIRECT=
DJANGO_HSTS_SECONDS=31536000
DJANGO_LOG_LEVEL=INFO
