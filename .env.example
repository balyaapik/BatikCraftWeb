# Generate fresh production keys:
#   python -c "import secrets; print(secrets.token_urlsafe(60))"
DJANGO_SECRET_KEY=change-me-in-production
# Use a separate stable value so stored R2 credentials remain decryptable when
# DJANGO_SECRET_KEY is rotated.
BATIKCRAFT_CREDENTIAL_ENCRYPTION_KEY=change-me-with-another-long-random-value

DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=

# SQLite development default: leave DATABASE_URL empty.
# PostgreSQL: postgresql://USER:PASSWORD@HOST:5432/batikcraft
# MySQL:      mysql://USER:PASSWORD@127.0.0.1:3306/batikcraft
DATABASE_URL=

# Mint registry. Keep the default until a real on-chain provider and contract
# are configured. Never store a wallet private key in this file or repository.
BATIKCRAFT_MINT_NETWORK=BatikCraft Registry
BATIKCRAFT_MINT_CONTRACT_ADDRESS=

# Midtrans Snap payment gateway. Start in Sandbox. Server Key is secret and must
# never be placed in templates, JavaScript, logs, screenshots, or Git history.
MIDTRANS_ENABLED=False
MIDTRANS_IS_PRODUCTION=False
MIDTRANS_MERCHANT_ID=
MIDTRANS_CLIENT_KEY=
MIDTRANS_SERVER_KEY=
MIDTRANS_HTTP_TIMEOUT=15
MIDTRANS_ALLOWED_PAYMENTS=qris,gopay,shopeepay,bca_va,bni_va,bri_va,echannel,permata_va

# Optional hardening. Both default to the safe value when DJANGO_DEBUG=False.
DJANGO_SECURE_SSL_REDIRECT=
DJANGO_HSTS_SECONDS=31536000
DJANGO_LOG_LEVEL=INFO
